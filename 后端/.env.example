# FastAPI
HOST=0.0.0.0
PORT=8800

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DB=eye_diagnosis_system_db

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# SMTP (QQ mail example)
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USER=your_email@qq.com
MAIL_PASSWORD=your_smtp_auth_code

# Model service
AI_MODEL_URL=http://127.0.0.1:5000

# Chat service (optional; if empty, /aiQuestion and /aiSuggestion will fail)
AI_CHAT_API_KEY=
AI_CHAT_HOST=api.chatanywhere.tech
AI_CHAT_PATH=/v1/chat/completions
AI_CHAT_MODEL=gpt-3.5-turbo

# JWT
JWT_SECRET_KEY=please_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=7
